# ═══════════════════════════════════════════════════════════════════════════════
# FacturePro Africa - Configuration Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────── Application ───────────────
APP_NAME=FacturePro Africa
APP_ENV=development
SECRET_KEY=change-me-super-secret-key-32chars-minimum-!!!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────── Database ───────────────
DATABASE_URL=postgresql+asyncpg://facturepro_user:facturepro_pass@localhost:5432/facturepro

# ─────────────── Redis & Celery ───────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0

# ─────────────── Email (SMTP) ───────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@facturepro.africa
SMTP_STARTTLS=false

# ─────────────── Admin Account ───────────────
ADMIN_EMAIL=admin@facturepro.africa
ADMIN_PASSWORD=Admin1234!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=System

# ─────────────── Logging & CORS ───────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3001,http://facturepro.localhost

# ─────────────── Rate Limiting ───────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENT PROVIDERS - African Markets
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────── CinetPay (UEMOA/CEMAC - XOF/XAF) ───────────────
# Countries: Côte d'Ivoire, Sénégal, Burkina Faso, Mali, Bénin, Togo, Niger, Cameroun
# Supports: Orange Money, MTN MoMo, Wave, Moov, Coris Money
# Get credentials: https://cinetpay.com/
CINETPAY_API_KEY=your_api_key
CINETPAY_SITE_ID=your_site_id
CINETPAY_SECRET_KEY=your_secret_key
CINETPAY_SANDBOX=true

# ─────────────── Paystack (Nigeria, Ghana, South Africa) ───────────────
# Countries: Nigeria, Ghana, South Africa
# Supports: Cards, Bank Transfer, USSD, QR, Mobile Money
# Get credentials: https://paystack.com/
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SANDBOX=true

# ─────────────── M-Pesa (Kenya, Tanzania, Ghana) ───────────────
# Countries: Kenya, Tanzania, Ghana, Uganda, Rwanda
# Supports: STK Push, C2B, B2C, B2B
# Get credentials: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_TILL_NUMBER=
MPESA_SANDBOX=true

# ─────────────── Pawapay (Panafrican) ───────────────
# Countries: 30+ African countries
# Supports: Multiple mobile money operators
# Get credentials: https://pawapay.io/
PAWAPAY_API_TOKEN=your_api_token
PAWAPAY_SANDBOX=true

# ─────────────── Payment Callback ───────────────
PAYMENT_CALLBACK_URL=https://your-domain.com/api/v1/payments/callback

# ═══════════════════════════════════════════════════════════════════════════════
# NOTIFICATION CHANNELS
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────── WhatsApp Business API ───────────────
# Get credentials: https://developers.facebook.com/docs/whatsapp
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ─────────────── Africa's Talking SMS ───────────────
# Countries: Kenya, Nigeria, Ghana, Uganda, Tanzania, Rwanda, Ethiopia, etc.
# Get credentials: https://africastalking.com/
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_SENDER_ID=SAVANA
AFRICASTALKING_SANDBOX=true

# ─────────────── Firebase Push Notifications ───────────────
# Get credentials: https://console.firebase.google.com/
FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING & ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────── Sentry ───────────────
# Get DSN: https://sentry.io/
SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────── Exchange Rates API ───────────────
# For multi-currency support
# Get API key: https://exchangerate-api.com/ or https://openexchangerates.org/
EXCHANGE_RATE_API_KEY=your_api_key
EXCHANGE_RATE_CACHE_HOURS=24
