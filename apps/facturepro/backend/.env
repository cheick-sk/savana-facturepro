# Copy this file to .env and fill in values
APP_NAME=FacturePro Africa
APP_ENV=development
SECRET_KEY=change-me-super-secret-key-32chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set by docker-compose; override locally:
DATABASE_URL=postgresql+asyncpg://facturepro_user:facturepro_pass@localhost:5432/facturepro

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@facturepro.africa
SMTP_STARTTLS=false

ADMIN_EMAIL=admin@facturepro.africa
ADMIN_PASSWORD=Admin1234!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=System

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3001,http://facturepro.localhost
