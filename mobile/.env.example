# API Configuration
API_BASE_URL=https://api.savana-africa.com
API_TIMEOUT=30000

# App Selection URLs
FACTUREPRO_API_URL=https://api.savana-africa.com/facturepro
SAVANAFLOW_API_URL=https://api.savana-africa.com/savanaflow
SCHOOLFLOW_API_URL=https://api.savana-africa.com/schoolflow

# Push Notifications
EXPO_PROJECT_ID=your-project-id

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_BARCODE_SCANNER=true
ENABLE_THERMAL_PRINTER=true

# Payment Gateway
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
PAYSTACK_PUBLIC_KEY=

# Localization
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en

# Sync Configuration
SYNC_INTERVAL=30000
MAX_OFFLINE_OPERATIONS=100
